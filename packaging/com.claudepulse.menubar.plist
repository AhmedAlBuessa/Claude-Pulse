<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Reference LaunchAgent for the Claude Pulse menu-bar app.

  Prefer `acp-bar --install`, which generates this file with the correct
  absolute path to your installed `acp-bar` and loads it. To install manually:

    1. Replace /REPLACE/WITH/PATH/TO/acp-bar below with the output of
       `which acp-bar`.
    2. Copy this file to ~/Library/LaunchAgents/com.claudepulse.menubar.plist
    3. launchctl load ~/Library/LaunchAgents/com.claudepulse.menubar.plist

  Uninstall with `acp-bar --uninstall`.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claudepulse.menubar</string>
    <key>ProgramArguments</key>
    <array>
        <string>/REPLACE/WITH/PATH/TO/acp-bar</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
